# Database (Neon - get from Neon dashboard > Connection Details)
# DATABASE_URL uses connection pooling (pgbouncer) - use for all app queries
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL bypasses pgbouncer - use for migrations only
DIRECT_URL="postgresql://[user]:[password]@[host].eu-west-2.aws.neon.tech/neondb?sslmode=require"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"

# Cloudflare R2
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="kathuniri-farm"
R2_PUBLIC_URL="https://[bucket].[account].r2.cloudflarestorage.com"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# Redis (for BullMQ job queue - use Upstash free tier)
REDIS_URL="redis://localhost:6379"

# SMS Utility shared secret
SMS_UTILITY_SECRET="change-me-to-random-string"

# Server
PORT=3000
NODE_ENV=development
